{
  "name": "slackaki",
  "version": "0.1.0",
  "description": "Iron Man's Jarvis for coding agents, inside Slack.",
  "type": "module",
  "bin": {
    "slackaki": "bin/slackaki.js"
  },
  "main": "dist/cli.js",
  "files": [
    "bin",
    "dist",
    "SPEC.md",
    "README.md"
  ],
  "scripts": {
